{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated",
        "--chromeArg=--no-first-run",
        "--chromeArg=--no-default-browser-check",
        "--no-usage-statistics"
      ]
    }
  },
  "agent": {
    "vision": {
      "description": "Analyzes images, screenshots, and visual content",
      "mode": "all",
      "model": "unsloth-studio/qwen3.5-27b-vision"
    }
  }
}
